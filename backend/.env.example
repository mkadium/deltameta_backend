# Copy to .env and fill with your values
# Required for database connection (pick one):

# Option A: Individual vars
PRIMARY_DB_HOST=localhost
PRIMARY_DB_PORT=5432
PRIMARY_DB_USER=postgres
PRIMARY_DB_PASSWORD=your_password
PRIMARY_DB_NAME=deltameta
PRIMARY_DB_SCHEMA=deltameta

# Option B: Single URL
# PRIMARY_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/deltameta

# Optional: CORS (comma-separated origins). If unset, allows any origin (*)
# CORS_ORIGINS=https://app.example.com,https://staging.example.com
