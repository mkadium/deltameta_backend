# Example environment variables for Deltameta backend
# Copy to .env and fill values; do NOT commit secrets.

# Primary database URL (asyncpg)
# Example: postgresql+asyncpg://user:password@localhost:5432/deltameta
PRIMARY_DATABASE_URL=

# Optional secondary database (analytics, replica, etc.)
SECONDARY_DATABASE_URL=

# Database schema to use by default
DB_SCHEMA=deltameta

# Other ENV examples
# SECRET_KEY=replace-with-secret
# SENTRY_DSN=

