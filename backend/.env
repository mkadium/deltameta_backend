# Example environment variables for Deltameta backend
# Copy to .env and fill values; do NOT commit secrets.

# Use individual variables for each connection (preferred)
# PRIMARY DB connection components
PRIMARY_DB_HOST=3.7.235.41
PRIMARY_DB_PORT=5434
PRIMARY_DB_USER=postgres
PRIMARY_DB_PASSWORD=EVrXabPjT6
PRIMARY_DB_NAME=deltameta
PRIMARY_DB_SCHEMA=deltameta

# Alternatively, set the full URL:
# PRIMARY_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/deltameta

# Optional secondary/replica DB components
SECONDARY_DB_HOST=
SECONDARY_DB_PORT=
SECONDARY_DB_USER=
SECONDARY_DB_PASSWORD=
SECONDARY_DB_NAME=
SECONDARY_DB_SCHEMA=

# Or full URL:
# SECONDARY_DATABASE_URL=postgresql+asyncpg://user:pass@host:port/otherdb

# JWT Auth Configuration
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256

# Global Admin Seed (used on first migration)
GLOBAL_ADMIN_EMAIL=admin@deltameta.io
GLOBAL_ADMIN_PASSWORD=Admin@123
GLOBAL_ADMIN_NAME=Global Admin

# OpenTelemetry Configuration
# Logs all traces, metrics, and logs to files in telemetry_logs/ folder
OTEL_ENABLED=false
OTEL_SERVICE_NAME=deltameta-backend
OTEL_ENVIRONMENT=development

# OTLP Exporter Endpoint (Jaeger, Tempo, Collector, etc.)
# Example for Jaeger: http://localhost:4317
# Example for Grafana Cloud: https://otlp-gateway-prod-<region>.grafana.net/otlp
# Leave empty to collect traces locally without exporting
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Other ENV examples
# SECRET_KEY=replace-with-secret
# SENTRY_DSN=

